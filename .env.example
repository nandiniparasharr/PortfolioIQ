# PortfolioIQ environment configuration
#
# All variables are OPTIONAL. The platform is fully functional without any
# external services: market data falls back to a deterministic synthetic
# provider and AI commentary falls back to a template-based generator.

# --- Market data -----------------------------------------------------------
# Provider for historical prices and instrument metadata.
#   "yahoo"     -> live Yahoo Finance (requires outbound network access)
#   "synthetic" -> deterministic, reproducible offline data (default)
MARKET_DATA_PROVIDER=synthetic

# --- AI commentary (OpenAI-compatible) -------------------------------------
# When unset, narrative commentary is generated deterministically from the
# computed analytics. When set, an OpenAI-compatible chat completion endpoint
# is used to phrase the (already computed) numbers.
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
